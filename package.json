{
  "name": "typescript-dsa-stl",
  "version": "3.0.0",
  "description": "STL-style data structures and algorithms for TypeScript: Vector, Stack, Queue, Deque (double-ended queue), List, PriorityQueue, Map, Set, sort, binarySearch, graph utilities. Use like C++ STL.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./collections": {
      "types": "./dist/collections/index.d.ts",
      "import": "./dist/collections/index.js",
      "default": "./dist/collections/index.js"
    },
    "./algorithms": {
      "types": "./dist/algorithms/index.d.ts",
      "import": "./dist/algorithms/index.js",
      "default": "./dist/algorithms/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "data-structures",
    "algorithms",
    "stl",
    "dsa",
    "vector",
    "stack",
    "queue",
    "deque",
    "double-ended-queue",
    "graph",
    "list",
    "priority-queue",
    "map",
    "set",
    "ordered-map",
    "unordered-map",
    "ordered-multimap",
    "ordered-multiset",
    "multimap",
    "multiset",
    "binary-search",
    "collections",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SajidAbdullah729/TypeScript_DSA.git"
  },
  "homepage": "https://github.com/SajidAbdullah729/TypeScript_DSA#readme",
  "bugs": {
    "url": "https://github.com/SajidAbdullah729/TypeScript_DSA/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
